# ============================================================
# .env.example - Template de variaveis de ambiente LOCAIS
# ============================================================
# Este arquivo e um template. Copie para .env e preencha os valores.
#
#   cp .env.example .env
#
# IMPORTANTE: .env nunca deve ser commitado (esta no .gitignore).
# Secrets de runtime (VERSION, WEBHOOK_SECRET) NAO vao aqui - sao
# injetados pelo Cloud Run via Secret Manager. Veja docs/SECRETS.md.
# ============================================================


# ----------- Jira Software (gerenciamento de backlog) -----------
# Site Atlassian onde estao as stories e epics (POC-*)
JIRA_URL=https://your-org.atlassian.net

# Email da conta usada para autenticar nas APIs do Atlassian
JIRA_EMAIL=your-email@example.com

# API token gerado em https://id.atlassian.com/manage-profile/security/api-tokens
# Permissoes necessarias: read/write em projetos Jira Software
JIRA_TOKEN=

# Chave do projeto Jira Software (ex: POC)
JIRA_PROJECT=POC


# ----------- Jira Service Management (governanca de GMUDs) -----------
# Pode ser o mesmo site que JIRA_URL ou site separado se JSM esta em conta Atlassian diferente
JSM_URL=https://your-org.atlassian.net

# Chave do projeto JSM onde as GMUDs sao abertas (ex: GMUD)
JSM_PROJECT=GMUD


# ----------- Confluence (documentacao) -----------
# Space key onde os ADRs, QA Evidence e Release Notes sao publicados
CONFLUENCE_SPACE=POCAntigra


# ----------- GitHub (repositorio) -----------
# Owner do repo (usuario ou org)
GITHUB_OWNER=

# Nome do repo
GITHUB_REPO=poc-antigravity

# Personal Access Token (PAT) com scopes: repo + workflow
# Gerar em: https://github.com/settings/tokens
GITHUB_TOKEN=


# ----------- Grafana Cloud (observabilidade) -----------
# URL do tenant Loki (sem path)
GRAFANA_LOKI_URL=https://logs-prod-XXX.grafana.net

# User ID numerico do tenant Grafana Cloud
GRAFANA_USER=

# API key do Grafana Cloud com escopo de write em logs
# Gerar em: https://grafana.com/orgs/<org>/api-keys
GRAFANA_TOKEN=